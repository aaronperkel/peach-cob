# Copy to .env.local and fill in. Never commit the real file.

# Database (TiDB Cloud Serverless — reachable from anywhere, TLS required)
DB_HOST=            # e.g. gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_NAME=peachcob
DB_USER=            # e.g. xxxxxxxxxxxx.root
DB_PASS=
DB_USE_SSL=true
DB_SSL_CA_PATH=     # optional; TiDB certs verify against public CAs without it

# Email (iCloud SMTP)
EMAIL_PASS=         # app-specific password from account.apple.com
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=          # SMTP login (primary iCloud address); empty = APP_EMAIL_FROM_ADDRESS
APP_EMAIL_FROM_ADDRESS=   # the From: address, e.g. noreply@... (must be an alias on the account)
APP_EMAIL_FROM_NAME=Peach Cob
APP_EMAIL_CONTACT_ADDRESS=  # footer/Reply-To human address; defaults to me@aaronperkel.com
APP_CONFIRMATION_EMAIL_TO=  # optional; batch confirmations go here when set

# App
APP_BASE_URL=https://peachcob.vercel.app
APP_BILLS_PER_PAGE=10

# Auth. Primary login is a one-time code emailed to a people.email address
# (needs the SMTP vars above). The house passphrase remains as a fallback.
SESSION_SECRET=          # openssl rand -hex 32
SITE_PASSPHRASE=         # fallback passphrase login; that path fails while unset
SITE_OWNER_EMAIL=me@aaronperkel.com  # people.email the passphrase session logs in as
APP_LOCAL_DEV_USER=      # set to a people.email to bypass login locally; empty in production
APP_DEMO_MODE=           # set to 1 to run the whole site off built-in fake data with no login
                         # and no database — for showing the site around. Never with real data.

# Bill PDF storage (Vercel Blob — token from the store's page under Vercel → Storage)
BLOB_READ_WRITE_TOKEN=

# Hourly reminder cron (app/api/cron/reminders); same value lives as a GitHub
# Actions repo secret and must be set in the Vercel project env.
CRON_SECRET=
